# ── SERVER ──────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── DATABASE ─────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://postgres:password@localhost:5432/agroconnect_dev"

# ── JWT ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_byte_random_hex
JWT_REFRESH_SECRET=replace_with_64_byte_random_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── SMS / OTP (Termii - Nigeria) ──────────────────
TERMII_API_KEY=
TERMII_SENDER_ID=AgroConnect

# ── EMAIL (SendGrid) ──────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=no-reply@agroconnect.ng

# ── STORAGE (Cloudinary) ──────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── PAYMENTS (Paystack) ───────────────────────────
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ── MAPS ─────────────────────────────────────────
MAPBOX_API_KEY=

# ── FRONTEND URL (for CORS) ───────────────────────
FRONTEND_URL=http://localhost:3000

# ── WHATSAPP (Twilio) ───────────────────────────
# Sign up at twilio.com — enable WhatsApp Sandbox or a production number
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886  # Twilio sandbox number

# ── LOGISTICS (Sendbox) ─────────────────────────
# Sign up at sendbox.co to get an API key
SENDBOX_API_KEY=

# ── ERROR TRACKING (Sentry) ──────────────────────
# Sign up at sentry.io — create a Node.js project
SENTRY_DSN=

# ── LOGGING ───────────────────────────────────────
# Pino log level: trace | debug | info | warn | error
LOG_LEVEL=info
